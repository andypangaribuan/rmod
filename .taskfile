#: do cargo build and lint
function run {
  cargo check
  cargo build
  cargo clippy && cargo fmt --check
}


#: clean the project
function clean {
  cargo clean
}


#: do cargo test
function test {
  cargo test -q -- --test-threads=1
}


#: run cspell to check the project words
function spell {
  spell-rs
}


#: space


#: open devbox shell #: opt: --fresh (delete .cargo and .rustup directories first)
function shell {
  if [ "$DEVBOX_SHELL_ENABLED" = "1" ]; then
    echo "ℹ️  You are already in an active Devbox shell."
    return 0
  fi

  if [[ $1 == "--fresh" ]]; then
    rm -rf .cargo .rustup
  fi

  DEVBOX_PROJECT_CWD="$PWD" devbox shell --config ~/.devbox/global/rust-1.93/devbox.json
}


#: show unused dependencies
function udeps {
  cargo +nightly udeps
}


#: remove unused directories
function rmd {
  rm -rf .cargo .devbox .rustup debug target test-debug
}


#: space


#: show contributor who make commits
function contributor {
  git log --pretty=format:"%an <%ae>" | sort | uniq
}


#: rewrite author
function rewrite-author {
  # brew install git-filter-repo
  git filter-repo --commit-callback '
  if (b"google-labs-jules" in commit.author_name or
      b"google-labs-jules" in commit.author_email):
      commit.author_name = b"Andy Pangaribuan"
      commit.author_email = b"iam.pangaribuan@gmail.com"
  '

  git config user.name "Andy Pangaribuan"
  git config user.email "iam.pangaribuan@gmail.com"

  git push --force --all
  git push --force --tags
}



#: space
[ -z "$TASKFILE_EXECUTOR" ] && sq taskfile --execute "$@"
